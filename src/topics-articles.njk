---
pagination:
  data: topics.topics
  size: 1
  alias: t
permalink: "/topics/{{ t.slug }}.html"
eleventyComputed:
  title: "{{ t.title }}"
layout: modern.njk
lang: ja
---

<section class="page-head">
  <div class="container">
    <span class="eyebrow">
      News{% if t.category %} ／ {{ t.category }}{% endif %}{% if t.subcategory %} ／ {{ t.subcategory }}{% endif %}
    </span>
    <h1>{{ t.title }}</h1>
    <p class="article-meta">
      <time datetime="{{ t.datetime }}">{{ t.date | replace("-", "/") }}</time>
      {% if t.author %}<span class="author">by {{ t.author }}</span>{% endif %}
    </p>
  </div>
</section>

<section class="section section-top-tight">
  <div class="container container-narrow-prose">
    {% if t.paper_title or t.url %}
    <aside class="article-refs">
      {% if t.paper_title %}
      <div class="article-ref">
        <span class="article-ref-label">論文</span>
        {% if t.doi %}
        <a href="https://doi.org/{{ t.doi }}" target="_blank" rel="noopener">{{ t.paper_title }}</a>
        <span class="article-ref-doi">DOI: {{ t.doi }}</span>
        {% else %}
        <span>{{ t.paper_title }}</span>
        {% endif %}
      </div>
      {% endif %}
      {% if t.url %}
      <div class="article-ref">
        <span class="article-ref-label">リンク</span>
        <a href="{{ t.url }}" target="_blank" rel="noopener">{{ t.url }}</a>
      </div>
      {% endif %}
    </aside>
    {% endif %}

    <article class="article-body">
      {{ t.body_html | safe }}
    </article>

    <div class="article-foot">
      <a class="btn btn-outline" href="/news/">← News 一覧へ戻る</a>
    </div>
  </div>
</section>
