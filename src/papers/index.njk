---
layout: base.njk
permalink: /papers/index.html
title: 論文紹介
bodyId: papers
---

<div id="contents">
  <div class="inner_contents">

    <div class="page_title">
      <h2>論文紹介</h2>
      <p class="subtitle">Publications</p>
    </div>

    <p class="papers-source">
      Data sources:
      <a href="https://openalex.org" target="_blank" rel="noopener">OpenAlex</a>
      ／
      <a href="https://opencitations.net" target="_blank" rel="noopener">OpenCitations</a>
      (Crossref Open Citations)
      <br>Last fetched: <time datetime="{{ papers.fetched_at }}">{{ papers.fetched_at.substring(0, 10) }}</time>
    </p>

    <!-- ============== Project Papers ============== -->
    <section class="papers-section project-papers">
      <h3 class="papers-section-title">
        Starrydata プロジェクト関連論文
        <span class="count">({{ papers.project_papers_count }})</span>
      </h3>
      <p class="papers-section-note">桂ゆかり氏らによる Starrydata プロジェクトの代表論文</p>

      <ul class="papers-list">
        {%- for p in papers.project_papers %}
        <li class="papers-item">
          <div class="paper-year">{{ p.year }}</div>
          <div class="paper-content">
            <p class="paper-title">
              {%- if p.doi_url %}
              <a href="{{ p.doi_url }}" target="_blank" rel="noopener">{{ p.title }}</a>
              {%- else %}
              {{ p.title }}
              {%- endif %}
            </p>
            {%- if p.authors %}<p class="paper-authors">{{ p.authors }}</p>{% endif %}
            <p class="paper-meta">
              {%- if p.journal %}<em class="journal">{{ p.journal }}</em>{% endif %}
              {%- if p.volume %} <strong>{{ p.volume }}</strong>{% endif %}
              {%- if p.issue %} [{{ p.issue }}]{% endif %}
              {%- if p.start_page %}, {{ p.start_page }}{% if p.end_page %}–{{ p.end_page }}{% endif %}{% endif %}
            </p>
            {%- if p.doi %}
            <p class="paper-doi">
              DOI: <a href="{{ p.doi_url }}" target="_blank" rel="noopener">{{ p.doi }}</a>
            </p>
            {%- endif %}
            {%- if p.cited_by_count %}
            <p class="paper-citations">
              <span class="citation-stat">Cited by <strong>{{ p.cited_by_count }}</strong>{% if p.cited_by_source == "crossref" %} (Crossref){% endif %}</span>
              {%- if p.cited_by_count_openalex and p.cited_by_count_openalex != p.cited_by_count %}
              <span class="citation-stat citation-detail">／ OpenAlex: {{ p.cited_by_count_openalex }}</span>
              {%- endif %}
            </p>
            {%- endif %}
          </div>
        </li>
        {%- endfor %}
      </ul>
    </section>

    <!-- ============== Citing Papers ============== -->
    <section class="papers-section citing-papers">
      <h3 class="papers-section-title">
        Starrydata を引用している論文
        <span class="count">({{ papers.citing_papers_count }})</span>
      </h3>
      <p class="papers-section-note">
        上記プロジェクト論文を引用している他研究者の論文（新しい順）<br>
        Sources: OpenAlex only {{ papers.citing_papers_by_source.openalex_only }} ／
        OpenCitations only {{ papers.citing_papers_by_source.opencitations_only }} ／
        both {{ papers.citing_papers_by_source.both }}
      </p>

      {%- for group in papers.citing_papers_by_year %}
      <details class="year-group" {% if loop.first %}open{% endif %}>
        <summary class="year-group-summary">
          <span class="year-label">{{ group.year or 'Year unknown' }}</span>
          <span class="year-count">{{ group.count }} papers</span>
        </summary>
        <ul class="papers-list">
          {%- for p in group.papers %}
          <li class="papers-item">
            <div class="paper-year">{{ p.year }}</div>
            <div class="paper-content">
              <p class="paper-title">
                {%- if p.doi_url %}
                <a href="{{ p.doi_url }}" target="_blank" rel="noopener">{{ p.title }}</a>
                {%- else %}
                {{ p.title }}
                {%- endif %}
              </p>
              {%- if p.authors %}<p class="paper-authors">{{ p.authors }}</p>{% endif %}
              <p class="paper-meta">
                {%- if p.journal %}<em class="journal">{{ p.journal }}</em>{% endif %}
                {%- if p.volume %} <strong>{{ p.volume }}</strong>{% endif %}
                {%- if p.issue %} [{{ p.issue }}]{% endif %}
                {%- if p.start_page %}, {{ p.start_page }}{% if p.end_page %}–{{ p.end_page }}{% endif %}{% endif %}
              </p>
              {%- if p.doi %}
              <p class="paper-doi">
                DOI: <a href="{{ p.doi_url }}" target="_blank" rel="noopener">{{ p.doi }}</a>
              </p>
              {%- endif %}
            </div>
          </li>
          {%- endfor %}
        </ul>
      </details>
      {%- endfor %}
    </section>

    <!-- ============== Dataset Citing Papers ============== -->
    <section class="papers-section dataset-citing-papers">
      <h3 class="papers-section-title">
        Starrydata dataset を引用している論文
        <span class="count">({{ papers.dataset_citing_papers_count }})</span>
      </h3>
      <p class="papers-section-note">
        figshare に公開された Starrydata の dataset DOI を引用している外部論文。<br>
        Scanned datasets: {{ papers.datasets_count }} ／ datasets with citations: {{ papers.datasets_with_citations }}
      </p>

      {%- if papers.dataset_citing_papers_count == 0 %}
      <p class="empty-note">現時点で dataset DOI を直接引用している論文は見つかりませんでした（多くの場合、論文 DOI 側で引用されています）。</p>
      {%- else %}
        {%- for group in papers.dataset_citing_papers_by_year %}
        <details class="year-group" {% if loop.first %}open{% endif %}>
          <summary class="year-group-summary">
            <span class="year-label">{{ group.year or 'Year unknown' }}</span>
            <span class="year-count">{{ group.count }} papers</span>
          </summary>
          <ul class="papers-list">
            {%- for p in group.papers %}
            <li class="papers-item">
              <div class="paper-year">{{ p.year }}</div>
              <div class="paper-content">
                <p class="paper-title">
                  {%- if p.doi_url %}
                  <a href="{{ p.doi_url }}" target="_blank" rel="noopener">{{ p.title }}</a>
                  {%- else %}
                  {{ p.title }}
                  {%- endif %}
                </p>
                {%- if p.authors %}<p class="paper-authors">{{ p.authors }}</p>{% endif %}
                <p class="paper-meta">
                  {%- if p.journal %}<em class="journal">{{ p.journal }}</em>{% endif %}
                  {%- if p.volume %} <strong>{{ p.volume }}</strong>{% endif %}
                  {%- if p.issue %} [{{ p.issue }}]{% endif %}
                  {%- if p.start_page %}, {{ p.start_page }}{% if p.end_page %}–{{ p.end_page }}{% endif %}{% endif %}
                </p>
                {%- if p.doi %}
                <p class="paper-doi">
                  DOI: <a href="{{ p.doi_url }}" target="_blank" rel="noopener">{{ p.doi }}</a>
                </p>
                {%- endif %}
                {%- if p.cited_datasets %}
                <p class="paper-cited-datasets">
                  引用 dataset:
                  {%- for d in p.cited_datasets %}
                  <a href="https://doi.org/{{ d }}" target="_blank" rel="noopener">{{ d }}</a>{% if not loop.last %},{% endif %}
                  {%- endfor %}
                </p>
                {%- endif %}
              </div>
            </li>
            {%- endfor %}
          </ul>
        </details>
        {%- endfor %}
      {%- endif %}
    </section>

  </div>
</div>
