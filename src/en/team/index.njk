---
layout: modern.njk
permalink: /en/team/index.html
title: Team
lang: en
---

{%- set L = "en" -%}

<section class="page-head">
  <div class="container">
    <span class="eyebrow">Team</span>
    <h1>Members</h1>
    <p class="lead lead-wide">{{ i18n.team.lead[L] }}</p>
  </div>
</section>

<section class="section section-top-tight">
  <div class="container">
    {%- for group in members.groups %}
      {%- if group.members | length > 0 %}
      <div class="team-group" data-group="{{ group.key }}">
        {% set label = group.label_en or group.label %}
        {% if label %}
        <h2 class="team-group-title">
          {{ label }}
          <span class="count">{{ group.members | length }}</span>
        </h2>
        {% endif %}

        {% if group.key == "alumni" %}
        <ul class="alumni-list">
          {%- for m in group.members %}
          <li>
            <span class="name-ja">{{ m.name_en }}</span>
            <span class="name-en">{{ m.name_ja }}</span>
          </li>
          {%- endfor %}
        </ul>
        {% else %}
        <div class="team-page-grid">
          {%- for m in group.members %}
          <article class="team-page-card">
            <div class="photo">
              {% if m.photo %}
                <img src="{{ m.photo }}" alt="{{ m.name_en }}" loading="lazy">
              {% else %}
                <div class="photo-placeholder">{{ m.name_en | first }}</div>
              {% endif %}
            </div>
            <div class="info">
              <h3 class="name">{{ m.name_en }}<span class="en">{{ m.name_ja }}</span></h3>
              {% set roleEn = m.role_en or m.role %}
              {% set affEn  = m.affiliation_en or m.affiliation %}
              {% if roleEn %}
              <p class="role">{{ roleEn | replace("\n", "<br>") | safe }}</p>
              {% endif %}
              {% if affEn %}
              <p class="aff">{{ affEn | replace("\n", "<br>") | safe }}</p>
              {% endif %}
              {% if m.links | length > 0 %}
              <ul class="links">
                {%- for l in m.links %}
                <li><a href="{{ l.href }}" target="_blank" rel="noopener">{{ l.label }}</a></li>
                {%- endfor %}
              </ul>
              {% endif %}
            </div>
          </article>
          {%- endfor %}
        </div>
        {% endif %}
      </div>
      {%- endif %}
    {%- endfor %}
  </div>
</section>
