<!DOCTYPE html>
<html lang="{{ lang or 'ja' }}">
<head prefix="og: http://ogp.me/ns#">
<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="robots" content="FOLLOW,INDEX">

{%- set L = lang or 'ja' -%}
{%- set siteName = i18n.site.name[L] -%}
{%- set siteTagline = i18n.site.tagline[L] -%}
{%- set siteDesc = i18n.site.description[L] -%}

<title>{% if title %}{{ title }} | {% endif %}{{ siteName }} — {{ siteTagline }}</title>
<meta name="description" content="{{ description or siteDesc }}">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+JP:wght@400;500;700;800&display=swap" rel="stylesheet">
<link href="/common/css/modern.css" rel="stylesheet">

<meta property="og:title" content="{{ siteName }} — {{ siteTagline }}">
<meta property="og:type" content="website">
<meta property="og:description" content="{{ description or siteDesc }}">
<meta property="og:locale" content="{{ 'ja_JP' if L == 'ja' else 'en_US' }}">
</head>
<body>

{% include "modern_header.njk" %}

<main>
{{ content | safe }}
</main>

{% include "modern_footer.njk" %}

<!-- Plotly.js (チャート用、遅延読み込み) -->
<script>
(function() {
  // チャート要素があるページのみ Plotly.js を読み込む
  if (!document.getElementById('chart-temp-seebeck')) return;
  const s = document.createElement('script');
  s.src = 'https://cdn.plot.ly/plotly-2.35.2.min.js';
  s.async = true;
  s.onload = () => drawTempSeebeck();
  document.head.appendChild(s);
})();

async function drawTempSeebeck() {
  try {
    const res = await fetch('/data/chart_temp_seebeck.json', { cache: 'no-store' });
    const d = await res.json();
    const trace = {
      x: d.data.T,
      y: d.data.S,
      text: d.data.comp,
      mode: 'markers',
      type: 'scattergl',
      marker: {
        size: 4,
        opacity: 0.55,
        color: d.data.T,
        colorscale: 'Plasma',
        showscale: true,
        colorbar: {
          title: { text: 'T (K)', font: { size: 11, color: '#475573' } },
          thickness: 12, len: 0.7,
          tickfont: { size: 10, color: '#475573' }
        }
      },
      hovertemplate:
        '<b>%{text}</b><br>T = %{x:.0f} K<br>S = %{y:.1f} μV/K<extra></extra>',
    };
    const layout = {
      margin: { t: 16, r: 12, b: 56, l: 64 },
      paper_bgcolor: 'rgba(0,0,0,0)',
      plot_bgcolor: '#fafaff',
      xaxis: {
        title: { text: d.x_label, font: { size: 13, color: '#1f1f3a' } },
        gridcolor: '#e6e6f1', zeroline: false,
        tickfont: { size: 11, color: '#475573' }
      },
      yaxis: {
        title: { text: d.y_label, font: { size: 13, color: '#1f1f3a' } },
        gridcolor: '#e6e6f1', zeroline: true, zerolinecolor: '#c4b5fd',
        tickfont: { size: 11, color: '#475573' }
      },
      font: { family: 'Inter, "Noto Sans JP", sans-serif' },
    };
    const config = { displaylogo: false, responsive: true,
      modeBarButtonsToRemove: ['lasso2d', 'select2d'] };
    Plotly.newPlot('chart-temp-seebeck', [trace], layout, config);

    const meta = document.getElementById('chart-temp-seebeck-meta');
    if (meta) {
      const date = (d.fetched_at || '').substring(0, 10);
      meta.textContent =
        `Source: Starrydata snapshot${d.snapshot ? ' ' + d.snapshot : ''}` +
        ` ／ ${d.point_count.toLocaleString('en-US')} points (sampled)` +
        ` ／ Fetched ${date}`;
    }
  } catch (e) {
    console.warn('chart load failed', e);
    const meta = document.getElementById('chart-temp-seebeck-meta');
    if (meta) meta.textContent = 'Chart data temporarily unavailable.';
  }
}
</script>

<script>
(function() {
  // counts.json から最新の Starrydata2 統計を取得
  // https://starrydata.github.io/json/counts.json （Starrydata 公式集計）
  const els = document.querySelectorAll('[data-counts]');
  if (!els.length) return;

  const fmt = n => n.toLocaleString('en-US');

  fetch('https://starrydata.github.io/json/counts.json', { cache: 'no-store' })
    .then(r => r.json())
    .then(d => {
      const fieldsCount = Object.keys(d.projects || {}).filter(k => k !== 'GeneralDB').length || null;
      const map = {
        samples: d.samples,
        curves:  d.curves,
        papers:  d.papers,
        figures: d.figures,
        fields:  fieldsCount,
      };
      els.forEach(el => {
        const key = el.dataset.counts;
        const v = map[key];
        if (v == null) return;
        el.textContent = fmt(v);
      });
    })
    .catch(err => {
      // フォールバックは HTML 内のハードコード値を維持
      console.warn('counts.json fetch failed; using fallback values', err);
    });
})();
</script>
</body>
</html>
