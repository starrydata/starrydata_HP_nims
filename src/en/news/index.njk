---
layout: modern.njk
permalink: /en/news/index.html
title: News
lang: en
---

{%- set L = "en" -%}

<section class="page-head">
  <div class="container">
    <span class="eyebrow">News</span>
    <h1>News</h1>
  </div>
</section>

<section class="section section-top-tight">
  <div class="container">
    <div class="news-list-box news-list-page">
      <ul class="news-list">
        {%- for t in topics.topics %}
        <li class="news-item">
          {% if t.url %}
          <a href="{{ t.url }}" target="_blank" rel="noopener" class="news-link-external">
          {% else %}
          <a href="#" data-news-idx="{{ loop.index0 }}">
          {% endif %}
            <time class="news-date" datetime="{{ t.datetime }}">{{ t.date | replace("-", "/") }}</time>
            <div class="news-text">
              {% if t.category or t.subcategory %}
              <div class="news-tags">
                {% if t.category %}<span class="news-tag news-tag-cat">{{ t.category }}</span>{% endif %}
                {% if t.subcategory %}<span class="news-tag news-tag-sub">{{ t.subcategory }}</span>{% endif %}
              </div>
              {% endif %}
              <h3 class="news-title">{{ t.title }}{% if t.url %} <span class="news-ext-icon" aria-hidden="true">↗</span>{% endif %}</h3>
              {% if t.summary %}<p class="news-summary">{{ t.summary }}</p>{% endif %}
            </div>
          </a>
        </li>
        {%- endfor %}
      </ul>
    </div>
  </div>
</section>

{% include "news_modal.njk" %}
