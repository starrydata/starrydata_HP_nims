<!DOCTYPE html>
<html lang="{{ lang or 'ja' }}">
<head prefix="og: http://ogp.me/ns#">
<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="robots" content="FOLLOW,INDEX">

{%- set L = lang or 'ja' -%}
{%- set siteName = i18n.site.name[L] -%}
{%- set siteTagline = i18n.site.tagline[L] -%}
{%- set siteDesc = i18n.site.description[L] -%}

<title>{% if title %}{{ title }} | {% endif %}{{ siteName }} — {{ siteTagline }}</title>
<meta name="description" content="{{ description or siteDesc }}">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+JP:wght@400;500;700;800&display=swap" rel="stylesheet">
<link href="/common/css/modern.css" rel="stylesheet">

<meta property="og:title" content="{{ siteName }} — {{ siteTagline }}">
<meta property="og:type" content="website">
<meta property="og:description" content="{{ description or siteDesc }}">
<meta property="og:locale" content="{{ 'ja_JP' if L == 'ja' else 'en_US' }}">
</head>
<body>

{% include "modern_header.njk" %}

<main>
{{ content | safe }}
</main>

{% include "modern_footer.njk" %}

<!-- Plotly.js (チャート用、遅延読み込み) -->
<script>
(function() {
  // チャート要素があるページのみ Plotly.js を読み込む
  if (!document.getElementById('chart-temp-seebeck')) return;
  const s = document.createElement('script');
  s.src = 'https://cdn.plot.ly/plotly-2.35.2.min.js';
  s.async = true;
  s.onload = () => drawTempSeebeck();
  document.head.appendChild(s);
})();

async function drawTempSeebeck() {
  try {
    const res = await fetch('/data/chart_temp_seebeck.json', { cache: 'no-store' });
    const d = await res.json();

    // ---- 組成別にグループ化、上位 N 件をカラフルなトレースに ----
    const groups = new Map();
    for (let i = 0; i < d.data.T.length; i++) {
      const c = d.data.comp[i] || '(unknown)';
      if (!groups.has(c)) groups.set(c, { T: [], S: [] });
      const g = groups.get(c);
      g.T.push(d.data.T[i]);
      g.S.push(d.data.S[i]);
    }
    // 件数の多い順にソート
    const sorted = [...groups.entries()].sort((a, b) => b[1].T.length - a[1].T.length);

    // Light24 + Bold + Alphabet + Vivid + Pastel から豊富な色
    const PALETTE = [
      '#FD3216','#00FE35','#6A76FC','#FED4C4','#FE00CE','#0DF9FF','#F6F926',
      '#FF9616','#479B55','#EEA6FB','#DC587D','#D626FF','#6E899C','#00B5F7',
      '#B68E00','#C9FBE5','#FF0092','#22FFA7','#E3EE9E','#86CE00','#BC7196',
      '#7E7DCD','#FC6955','#E48F72','#FFA8AB','#9C755F','#BAB0AC','#1F77B4',
      '#FF7F0E','#2CA02C','#D62728','#9467BD','#8C564B','#E377C2','#7F7F7F',
      '#BCBD22','#17BECF','#AEC7E8','#FFBB78','#98DF8A','#FF9896','#C5B0D5',
    ];

    const TOP_N = 40;
    const traces = [];

    // 上位 TOP_N 組成: 個別トレース（カラフル）
    sorted.slice(0, TOP_N).forEach(([comp, g], idx) => {
      traces.push({
        x: g.T, y: g.S,
        type: 'scattergl', mode: 'markers',
        name: comp,
        marker: {
          size: 5,
          opacity: 0.78,
          color: PALETTE[idx % PALETTE.length],
          line: { width: 0 },
        },
        hovertemplate: `<b>${comp}</b><br>T = %{x:.0f} K<br>S = %{y:.1f} μV/K<extra></extra>`,
      });
    });

    // それ以外は薄いグレーでまとめる
    if (sorted.length > TOP_N) {
      const otherX = [], otherY = [];
      sorted.slice(TOP_N).forEach(([, g]) => {
        otherX.push(...g.T); otherY.push(...g.S);
      });
      traces.unshift({
        x: otherX, y: otherY,
        type: 'scattergl', mode: 'markers',
        name: `others (${sorted.length - TOP_N} compositions)`,
        marker: { size: 3, opacity: 0.25, color: '#a5a8c0' },
        hoverinfo: 'skip',
      });
    }

    const layout = {
      margin: { t: 12, r: 12, b: 52, l: 60 },
      paper_bgcolor: 'rgba(0,0,0,0)',
      plot_bgcolor: '#0f0c29',
      showlegend: false,
      xaxis: {
        title: { text: 'Temperature (K)', font: { size: 13, color: '#c4b5fd' } },
        gridcolor: 'rgba(255,255,255,0.06)', zeroline: false,
        tickfont: { size: 11, color: '#a5a8c0' }, color: '#a5a8c0',
      },
      yaxis: {
        title: { text: 'Seebeck coefficient (μV/K)', font: { size: 13, color: '#c4b5fd' } },
        gridcolor: 'rgba(255,255,255,0.06)', zeroline: true, zerolinecolor: 'rgba(167,139,250,0.4)',
        tickfont: { size: 11, color: '#a5a8c0' }, color: '#a5a8c0',
      },
      font: { family: 'Inter, "Noto Sans JP", sans-serif' },
    };
    const config = { displaylogo: false, responsive: true,
      modeBarButtonsToRemove: ['lasso2d', 'select2d'] };
    Plotly.newPlot('chart-temp-seebeck', traces, layout, config);

    const meta = document.getElementById('chart-temp-seebeck-meta');
    if (meta) {
      const date = (d.fetched_at || '').substring(0, 10);
      meta.textContent =
        `Source: Starrydata snapshot${d.snapshot ? ' ' + d.snapshot : ''}` +
        ` ／ ${d.point_count.toLocaleString('en-US')} points, ${sorted.length.toLocaleString('en-US')} compositions` +
        ` ／ Fetched ${date}`;
    }
  } catch (e) {
    console.warn('chart load failed', e);
    const meta = document.getElementById('chart-temp-seebeck-meta');
    if (meta) meta.textContent = 'Chart data temporarily unavailable.';
  }
}
</script>

<script>
(function() {
  // counts.json から最新の Starrydata2 統計を取得
  // https://starrydata.github.io/json/counts.json （Starrydata 公式集計）
  const els = document.querySelectorAll('[data-counts]');
  if (!els.length) return;

  const fmt = n => n.toLocaleString('en-US');

  fetch('https://starrydata.github.io/json/counts.json', { cache: 'no-store' })
    .then(r => r.json())
    .then(d => {
      const fieldsCount = Object.keys(d.projects || {}).filter(k => k !== 'GeneralDB').length || null;
      const map = {
        samples: d.samples,
        curves:  d.curves,
        papers:  d.papers,
        figures: d.figures,
        fields:  fieldsCount,
      };
      els.forEach(el => {
        const key = el.dataset.counts;
        const v = map[key];
        if (v == null) return;
        el.textContent = fmt(v);
      });
    })
    .catch(err => {
      // フォールバックは HTML 内のハードコード値を維持
      console.warn('counts.json fetch failed; using fallback values', err);
    });
})();
</script>
</body>
</html>
