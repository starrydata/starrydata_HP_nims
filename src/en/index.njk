---
layout: modern.njk
permalink: /en/index.html
title:
lang: en
---

{%- set L = "en" -%}

<!-- =================== HERO =================== -->
<section class="hero">
  <div class="container">
    <span class="hero-eyebrow">An Open Database for Materials Informatics</span>
    <h1>
      {{ i18n.hero.headline_1[L] }}<br>
      <span class="accent">{{ i18n.hero.headline_2[L] }}</span>
    </h1>
    <p class="lead">{{ i18n.hero.subline[L] }}</p>
    <div class="hero-ctas">
      <a class="btn btn-primary" href="https://www.starrydata2.org" target="_blank" rel="noopener">
        {{ i18n.hero.cta_primary[L] }} →
      </a>
      <a class="btn btn-ghost" href="#collaborate">
        {{ i18n.hero.cta_secondary[L] }}
      </a>
    </div>
  </div>
</section>

<!-- =================== STATS =================== -->
<section class="stats">
  <div class="container">
    <div class="stat"><div class="num" data-counts="samples">104,823</div><div class="label">{{ i18n.stats.samples[L] }}</div></div>
    <div class="stat"><div class="num" data-counts="curves">233,061</div><div class="label">{{ i18n.stats.curves[L] }}</div></div>
    <div class="stat"><div class="num" data-counts="papers">17,326</div><div class="label">{{ i18n.stats.papers[L] }}</div></div>
    <div class="stat"><div class="num" data-counts="fields">12</div><div class="label">{{ i18n.stats.fields[L] }}</div></div>
  </div>
</section>

<!-- =================== WHAT IS =================== -->
<section class="section" id="about">
  <div class="container">
    <span class="eyebrow">About</span>
    <h2>{{ i18n.what_is.title[L] }}</h2>
    <p class="lead">{{ i18n.what_is.lead[L] }}</p>

    <div class="feature-grid">
      <div class="feature-card">
        <div class="icon">DB</div>
        <h3>{{ i18n.what_is.point1_t[L] }}</h3>
        <p>{{ i18n.what_is.point1_d[L] }}</p>
      </div>
      <div class="feature-card">
        <div class="icon">API</div>
        <h3>{{ i18n.what_is.point2_t[L] }}</h3>
        <p>{{ i18n.what_is.point2_d[L] }}</p>
      </div>
      <div class="feature-card">
        <div class="icon">↑</div>
        <h3>{{ i18n.what_is.point3_t[L] }}</h3>
        <p>{{ i18n.what_is.point3_d[L] }}</p>
      </div>
    </div>
  </div>
</section>

<!-- =================== RESEARCH FIELDS =================== -->
<section class="section" id="research" style="background:#fff; border-top:1px solid var(--line); border-bottom:1px solid var(--line);">
  <div class="container">
    <span class="eyebrow">Research</span>
    <h2>{{ i18n.fields.title[L] }}</h2>
    <p class="lead">Seven research fields powering data curation and Materials Informatics studies.</p>

    <div class="fields-grid">
      <a class="field-card" href="/data/thermoelectric.html">
        <div class="field-num">01</div><h3>Thermoelectric</h3><div class="en">熱電材料</div></a>
      <a class="field-card" href="/data/magnetic.html">
        <div class="field-num">02</div><h3>Magnetic</h3><div class="en">磁性材料</div></a>
      <a class="field-card" href="/data/quasicrystal.html">
        <div class="field-num">03</div><h3>Quasicrystal</h3><div class="en">準結晶</div></a>
      <a class="field-card" href="/data/condensed.html">
        <div class="field-num">04</div><h3>Condensed Matter</h3><div class="en">固体物性</div></a>
      <a class="field-card" href="/data/battery.html">
        <div class="field-num">05</div><h3>Battery</h3><div class="en">電池材料</div></a>
      <a class="field-card" href="/data/piezoelectric.html">
        <div class="field-num">06</div><h3>Piezoelectric</h3><div class="en">圧電材料</div></a>
      <a class="field-card" href="#">
        <div class="field-num">07</div><h3>Dielectric</h3><div class="en">誘電材料</div></a>
      <a class="field-card" href="#">
        <div class="field-num">+</div><h3>More coming</h3><div class="en">expanding</div></a>
    </div>
  </div>
</section>

<!-- =================== PUBLICATIONS =================== -->
<section class="section" id="publications">
  <div class="container">
    <span class="eyebrow">Publications</span>
    <h2>{{ i18n.publications.title[L] }}</h2>
    <p class="lead">Top 3 of 8 project papers from the Starrydata team. 184 external publications cite our work.</p>

    <div class="card-grid">
      {%- for p in papers.project_papers.slice(0, 3) %}
      <article class="mini-card">
        <div class="meta"><span class="tag">Paper</span>{{ p.year }}</div>
        <h3><a href="{{ p.doi_url }}" target="_blank" rel="noopener">{{ p.title }}</a></h3>
        <p>{{ p.authors }}</p>
      </article>
      {%- endfor %}
    </div>

    <div class="section-foot">
      <a class="btn btn-outline" href="/papers/index.html">{{ i18n.publications.see_all[L] }} →</a>
    </div>
  </div>
</section>

<!-- =================== NEWS =================== -->
<section class="section" id="news" style="background:#fff; border-top:1px solid var(--line); border-bottom:1px solid var(--line);">
  <div class="container">
    <span class="eyebrow">News</span>
    <h2>{{ i18n.news.title[L] }}</h2>

    <div class="card-grid">
      {%- for t in topics.topics.slice(0, 3) %}
      <article class="mini-card">
        <div class="meta"><span class="tag">News</span>{{ t.date }}</div>
        <h3><a href="/topics/{{ t.slug }}.html">{{ t.title }}</a></h3>
        <p>{{ t.summary }}</p>
      </article>
      {%- endfor %}
    </div>

    <div class="section-foot">
      <a class="btn btn-outline" href="/topics/index.html">{{ i18n.news.see_all[L] }} →</a>
    </div>
  </div>
</section>

<!-- =================== COLLABORATE CTA =================== -->
<section class="section" id="collaborate">
  <div class="cta-band">
    <span class="eyebrow" style="color:#b6f0ff;">Collaborate</span>
    <h2>{{ i18n.collaborate.title[L] }}</h2>
    <p>{{ i18n.collaborate.lead[L] }}</p>
    <a class="btn btn-primary" href="#contact">{{ i18n.collaborate.cta[L] }} →</a>
  </div>
</section>

<!-- =================== TEAM =================== -->
<section class="section" id="team">
  <div class="container">
    <span class="eyebrow">Team</span>
    <h2>{{ i18n.team.title[L] }}</h2>
    <p class="lead">Starrydata runs as a dedicated team of researchers and engineers in materials science, data science, and web development.</p>

    <div class="team-grid">
      {%- for m in members.groups[0].members.slice(0, 5) %}
      <div class="member-card">
        {% if m.photo %}<img class="photo" src="{{ m.photo }}" alt="{{ m.name_en }}">{% else %}<div class="photo"></div>{% endif %}
        <h4>{{ m.name_en }}</h4>
        <div class="role">{{ m.role }}</div>
      </div>
      {%- endfor %}
    </div>

    <div class="section-foot">
      <a class="btn btn-outline" href="/project/members.html">{{ i18n.team.see_all[L] }} →</a>
    </div>
  </div>
</section>

<!-- =================== PARTNERS =================== -->
<section class="section-narrow">
  <div class="container">
    <p style="text-align:center; color:var(--text-3); letter-spacing:.15em; text-transform:uppercase; font-size:.78rem; font-weight:600; margin-bottom:24px;">
      {{ i18n.funding.title[L] }}
    </p>
    <div class="partner-row">
      <div class="partner">NIMS</div>
      <div class="partner">RIKEN AIP</div>
      <div class="partner">JST</div>
      <div class="partner">Univ. of Tsukuba</div>
      <div class="partner">SAKURA internet</div>
    </div>
  </div>
</section>
