---
layout: modern.njk
permalink: /en/index.html
title:
lang: en
---

{%- set L = "en" -%}

<!-- =================== HERO =================== -->
<section class="hero">
  <div class="container">
    <span class="hero-eyebrow">An Open Database for Materials Informatics</span>
    <h1>
      {{ i18n.hero.headline_1[L] | safe }}<br>
      {{ i18n.hero.headline_2[L] | safe }}
    </h1>
    <p class="lead">{{ i18n.hero.subline[L] }}</p>
    <div class="hero-ctas">
      <a class="btn btn-primary" href="https://www.starrydata2.org" target="_blank" rel="noopener">
        {{ i18n.hero.cta_primary[L] }} →
      </a>
      <a class="btn btn-ghost" href="#collaborate">
        {{ i18n.hero.cta_secondary[L] }}
      </a>
    </div>
  </div>
</section>

<!-- =================== STATS =================== -->
<section class="stats">
  <div class="container">
    <div class="stat"><div class="num" data-counts="samples">104,823</div><div class="label">{{ i18n.stats.samples[L] }}</div></div>
    <div class="stat"><div class="num" data-counts="curves">233,061</div><div class="label">{{ i18n.stats.curves[L] }}</div></div>
    <div class="stat"><div class="num" data-counts="papers">17,326</div><div class="label">{{ i18n.stats.papers[L] }}</div></div>
    <div class="stat"><div class="num" data-counts="fields">12</div><div class="label">{{ i18n.stats.fields[L] }}</div></div>
  </div>
</section>

<!-- =================== WHAT IS =================== -->
<section class="section" id="about">
  <div class="container container-narrow-prose">
    <span class="eyebrow">About the Project</span>
    <h2>{{ i18n.what_is.title[L] }}</h2>
    <p class="lead-large">{{ i18n.what_is.lead[L] | safe }}</p>
    <p class="prose">{{ i18n.what_is.body[L] }}</p>
  </div>
</section>

<section class="section" id="huge-database" style="background:#fff; border-top:1px solid var(--line); border-bottom:1px solid var(--line);">
  <div class="container">
    <div class="grid-2col">
      <div class="text-col">
        <span class="eyebrow">Massive Dataset</span>
        <h2>{{ i18n.huge_db.title[L] }}</h2>
        <p class="lead">
          <strong data-counts="samples">104,823</strong> samples and <strong data-counts="curves">233,061</strong> curves from 13,000+ papers.
          Numerical data carefully extracted from plots in literature, ready for machine learning and data analysis.
        </p>
        <ul class="kv-list">
          <li><span class="k">Samples</span><span class="v" data-counts="samples">104,823</span></li>
          <li><span class="k">Curves</span><span class="v" data-counts="curves">233,061</span></li>
          <li><span class="k">Papers</span><span class="v" data-counts="papers">17,326</span></li>
          <li><span class="k">Updated</span><span class="v">Daily</span></li>
        </ul>
        <div class="hero-ctas" style="margin-top:28px;">
          <a class="btn btn-primary" href="https://www.starrydata2.org" target="_blank" rel="noopener">{{ i18n.huge_db.cta[L] }}</a>
        </div>
      </div>
      <div class="chart-col">
        <div id="chart-temp-seebeck" style="width:100%;height:520px;"></div>
        <p class="chart-meta" id="chart-temp-seebeck-meta">Loading…</p>
      </div>
    </div>
  </div>
</section>

<section class="section" id="apps">
  <div class="container">
    <span class="eyebrow">Apps &amp; Systems</span>
    <h2>{{ i18n.apps.title[L] }}</h2>
    <p class="lead">{{ i18n.apps.lead[L] }}</p>

    <div class="apps-grid">
      {%- for a in apps.apps %}
      <a class="app-card" href="{{ a.url }}" target="_blank" rel="noopener" data-image-layout="{{ a.image_layout or 'default' }}">
        {% if a.image %}
        <div class="app-thumb"><img src="{{ a.image }}" alt="{{ a.name[L] }}" loading="lazy"></div>
        {% else %}
        <div class="app-thumb app-thumb-placeholder"><span>{{ a.icon }}</span></div>
        {% endif %}
        <div class="app-body">
          <h3>{{ a.name[L] }}</h3>
          <p class="app-sub">{{ a.subtitle[L] }}</p>
          <p class="app-desc">{{ a.description[L] }}</p>
        </div>
        <span class="app-open">{{ i18n.apps.open[L] }} ↗</span>
      </a>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section" id="get-involved" style="background:#fff; border-top:1px solid var(--line); border-bottom:1px solid var(--line);">
  <div class="container">
    <span class="eyebrow">Get Involved</span>
    <h2>{{ i18n.get_involved.title[L] }}</h2>
    <p class="lead">{{ i18n.get_involved.lead[L] }}</p>

    <div class="involve-grid">
      <div class="involve-card">
        <span class="tag use">USE</span>
        <h3>{{ i18n.get_involved.card1_t[L] }}</h3>
        <p>{{ i18n.get_involved.card1_d[L] }}</p>
        <a class="btn btn-outline" href="https://www.starrydata2.org" target="_blank" rel="noopener">{{ i18n.get_involved.card1_cta[L] }}</a>
      </div>
      <div class="involve-card">
        <span class="tag contribute">CONTRIBUTE</span>
        <h3>{{ i18n.get_involved.card2_t[L] }}</h3>
        <p>{{ i18n.get_involved.card2_d[L] }}</p>
        <a class="btn btn-outline" href="#collaborate">{{ i18n.get_involved.card2_cta[L] }}</a>
      </div>
      <div class="involve-card highlight">
        <span class="tag partner">PARTNER</span>
        <h3>{{ i18n.get_involved.card3_t[L] }}</h3>
        <p>{{ i18n.get_involved.card3_d[L] }}</p>
        <a class="btn btn-primary" href="#collaborate">{{ i18n.get_involved.card3_cta[L] }}</a>
      </div>
    </div>
  </div>
</section>

<!-- =================== RESEARCH FIELDS =================== -->
<section class="section" id="research" style="background:#fff; border-top:1px solid var(--line); border-bottom:1px solid var(--line);">
  <div class="container">
    <span class="eyebrow">Research</span>
    <h2>{{ i18n.fields.title[L] }}</h2>
    <p class="lead lead-wide">Seven research fields powering data curation and Materials Informatics studies.</p>

    <div class="fields-grid">
      <a class="field-card" href="/en/research/#thermoelectric">
        <div class="field-num">01</div><h3>Thermoelectric</h3><div class="en">熱電材料</div></a>
      <a class="field-card" href="/en/research/#battery">
        <div class="field-num">02</div><h3>Battery</h3><div class="en">電池材料</div></a>
      <a class="field-card" href="/en/research/#magnetic">
        <div class="field-num">03</div><h3>Magnetic</h3><div class="en">磁性材料</div></a>
      <a class="field-card" href="/en/research/#dielectric">
        <div class="field-num">04</div><h3>Dielectric</h3><div class="en">誘電材料</div></a>
      <a class="field-card" href="/en/research/#condensed-matter">
        <div class="field-num">05</div><h3>Condensed Matter</h3><div class="en">固体物性</div></a>
      <a class="field-card" href="/en/research/#piezoelectric">
        <div class="field-num">06</div><h3>Piezoelectric</h3><div class="en">圧電材料</div></a>
      <a class="field-card" href="/en/research/#hypermaterial">
        <div class="field-num">07</div><h3>Hypermaterial</h3><div class="en">準結晶</div></a>
      <a class="field-card" href="/en/research/">
        <div class="field-num">+</div><h3>View all</h3><div class="en">12 fields</div></a>
    </div>
  </div>
</section>

<!-- =================== PUBLICATIONS =================== -->
<section class="section" id="publications">
  <div class="container">
    <span class="eyebrow">Publications</span>
    <h2>{{ i18n.publications.title[L] }}</h2>
    <p class="lead lead-wide">Top 3 of {{ papers.project_papers_count }} project papers from the Starrydata team. {{ papers.citing_papers_count }} external publications cite our work.</p>

    <div class="card-grid">
      {%- for p in papers.project_papers.slice(0, 3) %}
      <article class="mini-card">
        <div class="meta"><span class="tag">Paper</span>{{ p.year }}</div>
        <h3><a href="{{ p.doi_url }}" target="_blank" rel="noopener">{{ p.title }}</a></h3>
        <p>{{ p.authors }}</p>
      </article>
      {%- endfor %}
    </div>

    <div class="section-foot">
      <a class="btn btn-outline" href="/en/papers/">{{ i18n.publications.see_all[L] }} →</a>
    </div>
  </div>
</section>

<!-- =================== NEWS =================== -->
<section class="section" id="news" style="background:#fff; border-top:1px solid var(--line); border-bottom:1px solid var(--line);">
  <div class="container">
    <span class="eyebrow">News</span>
    <h2>{{ i18n.news.title[L] }}</h2>

    <div class="news-list-box">
      <ul class="news-list">
        {%- for t in topics.topics.slice(0, 5) %}
        <li class="news-item">
          <a href="/topics/{{ t.slug }}.html">
            <time class="news-date" datetime="{{ t.datetime }}">{{ t.date | replace("-", "/") }}</time>
            <div class="news-text">
              {% if t.category or t.subcategory %}
              <div class="news-tags">
                {% if t.category %}<span class="news-tag news-tag-cat">{{ t.category }}</span>{% endif %}
                {% if t.subcategory %}<span class="news-tag news-tag-sub">{{ t.subcategory }}</span>{% endif %}
              </div>
              {% endif %}
              <h3 class="news-title">{{ t.title }}</h3>
              {% if t.summary %}<p class="news-summary">{{ t.summary }}</p>{% endif %}
            </div>
          </a>
        </li>
        {%- endfor %}
      </ul>
    </div>

    <div class="section-foot">
      <a class="btn btn-outline" href="/en/news/">{{ i18n.news.see_all[L] }} →</a>
    </div>
  </div>
</section>

<!-- =================== COLLABORATE CTA =================== -->
<section class="section" id="collaborate">
  <div class="cta-band">
    <span class="eyebrow" style="color:#b6f0ff;">Collaborate</span>
    <h2>{{ i18n.collaborate.title[L] | safe }}</h2>
    <p>{{ i18n.collaborate.lead[L] }}</p>
    <a class="btn btn-primary" href="#contact">{{ i18n.collaborate.cta[L] }} →</a>
  </div>
</section>

<!-- =================== TEAM =================== -->
<section class="section" id="team">
  <div class="container">
    <span class="eyebrow">Team</span>
    <h2>{{ i18n.team.title[L] }}</h2>
    <p class="lead">Starrydata runs as a dedicated team of researchers and engineers in materials science, data science, and web development.</p>

    <div class="team-grid">
      {%- for m in members.groups[0].members.slice(0, 5) %}
      <div class="member-card">
        {% if m.photo %}<img class="photo" src="{{ m.photo }}" alt="{{ m.name_en }}">{% else %}<div class="photo"></div>{% endif %}
        <h4>{{ m.name_en }}</h4>
        <div class="role">{{ (m.role_en or m.role) | replace("\n", " ") | safe }}</div>
      </div>
      {%- endfor %}
    </div>

    <div class="section-foot">
      <a class="btn btn-outline" href="/en/team/">{{ i18n.team.see_all[L] }} →</a>
    </div>
  </div>
</section>

<!-- =================== PARTNERS =================== -->
<section class="section-narrow">
  <div class="container">
    <p style="text-align:center; color:var(--text-3); letter-spacing:.15em; text-transform:uppercase; font-size:.78rem; font-weight:600; margin-bottom:24px;">
      {{ i18n.funding.title[L] }}
    </p>
    <div class="partner-row">
      <div class="partner">NIMS</div>
      <div class="partner">RIKEN AIP</div>
      <div class="partner">JST</div>
      <div class="partner">Univ. of Tsukuba</div>
      <div class="partner">SAKURA internet</div>
    </div>
  </div>
</section>
